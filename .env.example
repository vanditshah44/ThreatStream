APP_NAME=ThreatStream API
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true

API_PREFIX=/api
API_VERSION=v1

LOG_LEVEL=INFO
ADMIN_API_TOKEN=change-this-to-a-long-random-secret
THREATSTREAM_ADMIN_BASE_URL=http://127.0.0.1:8000

DATABASE_URL=sqlite:///./threatstream.db
DATABASE_ECHO=false
AUTO_CREATE_TABLES=true
AUTO_REPAIR_SQLITE_SCHEMA=false

CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
ALLOW_UNSAFE_FEED_URLS=false

HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=2
HTTP_USER_AGENT=ThreatStream/0.1.0

CISA_KEV_CATALOG_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
CISA_KEV_CATALOG_PAGE_URL=https://www.cisa.gov/known-exploited-vulnerabilities-catalog

URLHAUS_API_BASE_URL=https://urlhaus-api.abuse.ch
URLHAUS_AUTH_KEY=
URLHAUS_RECENT_LIMIT=1000

OPENPHISH_FEED_URL=https://openphish.com/feed.txt

RANSOMWARE_LIVE_RECENT_VICTIMS_URL=https://api.ransomware.live/v2/recentvictims
